{
  "name": "nesa-router",
  "version": "0.1.47",
  "private": true,
  "license": "MIT",
  "description": "NesaRouter - Next Smart Adaptive Router",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node scripts/ensure-port-free.mjs && next dev --port 20129",
    "build": "next build",
    "start": "node scripts/ensure-port-free.mjs && node scripts/start-standalone.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "unlock-admin": "node scripts/unlock-admin.mjs",
    "cursor:export": "node scripts/cursor-export.mjs",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "check:public-boundary": "node scripts/check-public-boundary.mjs",
    "test": "npm run check:public-boundary && vitest run",
    "test:coverage": "npm run check:public-boundary && vitest run --coverage",
    "pretest:e2e": "node scripts/prepare-e2e.mjs",
    "test:e2e": "playwright test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socks-proxy-agent": "^8.0.5",
    "undici": "^6.27.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.20",
    "sharp": "^0.35.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "sharp": "^0.35.3"
  }
}
