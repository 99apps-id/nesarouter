PORT=20129
DATA_DIR=data

# Required in production (NODE_ENV=production). Long random secret used for
# AES-GCM encryption of API keys, OAuth tokens, client /v1 keys, pending OAuth
# secrets, and (by default) admin-session cookie HMAC.
# Generate e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NESA_ENCRYPTION_KEY=replace-with-long-random-secret

# Optional separate session HMAC secret (falls back to NESA_ENCRYPTION_KEY).
# Session cookies are random + HMAC-signed; hashes live in SQLite and are revocable.
# NESA_ADMIN_SESSION_SECRET=

# Initial admin password bootstrap (used until you change it in Routing > Password).
# Default if unset in development: nesa123456
# Production refuses the default / change-me values — set a unique password and tell the operator.
# Installers: do not silently randomize this without printing it to the operator.
NESA_ADMIN_PASSWORD=change-me

# Optional admin OAuth (GitHub / Google) for dashboard login. Restrict who can log in:
NESA_OAUTH_ALLOWED_EMAILS=admin@example.com
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional update check against GitHub Releases (dashboard banner). Default: on.
# NESA_UPDATE_CHECK=false
# NESA_GITHUB_REPO=99apps-id/nesarouter

# Optional Headroom proxy URL (default http://localhost:8787)
# HEADROOM_URL=http://localhost:8787
